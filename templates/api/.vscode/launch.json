            "stopAtEntry": false,
            "env": {
                "ASPNETCORE_URLS": "http://localhost:5237",
                "ASPNETCORE_ENVIRONMENT": "Development",
                "DAPR_APP_ID": "myprojectname-app",
                "DAPR_HTTP_PORT": "42010",
                "DAPR_GRPC_PORT": "42011",
                "DAPR_SECRET_STORE_NAME": "myprojectname-secret",
                "DAPR_STATE_STORE_NAME": "myprojectname-cache",
                "DAPR_PUBSUB_STORE_NAME": "myprojectname-pubsub",
                "DAPR_LOCK_STORE_NAME": "myprojectname-lock",
                "DAPR_PLACEMENT_HOST": "localhost:50005",
                "OTEL_EXPORTER_OTLP_ENDPOINT": "http://localhost:4318",
                "OTEL_EXPORTER_OTLP_PROTOCOL": "http/protobuf",
                "OTEL_SERVICE_NAME": "myprojectname-app",
                "OTEL_BLRP_SCHEDULE_DELAY": "1000",
                "OTEL_BSP_SCHEDULE_DELAY": "1000",
                "OTEL_LOGS_EXPORTER": "otlp"
            },
            "postDebugTask": "daprd-down",
            "serverReadyAction": {
                "action": "openExternally",
                "pattern": "\\bNow listening on:\\s+(https?://\\S+)",
                "uriFormat": "%s/swagger/"
            }
        }
    ]
}