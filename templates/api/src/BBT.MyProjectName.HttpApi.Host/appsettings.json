{
  "ConnectionStrings": {
    "Default": "Host=localhost,5432;Database=AetherMyProjectNameDb;Username=postgres;Password=postgres"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "System.Net.Http.HttpClient.OtlpTraceExporter.LogicalHandler": "Warning",
      "Microsoft.AspNetCore.Routing.EndpointMiddleware": "Warning",
      "System.Net.Http.HttpClient.Default.LogicalHandler": "Warning",
      "Microsoft.EntityFrameworkCore.Database.Command": "Warning"
    }
  },
  "ResponseCompression": {
    "Enable": true,
    "Providers": ["gzip"],
    "EnableForHttps": true,
    "MimeTypes": [],
    "ExcludedMimeTypes": []
  },
  "Redis": {
    "Mode": "Standalone",
    "InstanceName": "myprojectname-api",
    "ConnectionTimeout": 5000,
    "DefaultDatabase": 0,
    "Password": "",
    "Ssl": false,
    "Standalone": {
      "EndPoints": ["localhost:6378"]
    },
    "Cluster": {
      "EndPoints": ["localhost:7000", "localhost:7001", "localhost:7002"],
      "MaxRedirects": 3
    },
    "Sentinel": {
      "Masters": ["mymaster"],
      "Sentinels": ["localhost:26379", "localhost:26380"],
      "DefaultDatabase": 0
    },
    "RetryPolicy": {
      "MaxRetries": 3,
      "RetryTimeout": 1000
    }
  },
  "Telemetry": {
    "ServiceName": "MyProjectName",
    "ServiceNamespace": "BBT.MyProjectName",
    "ServiceVersion": "1.0.0",
    "TracingEnabled": true,
    "MetricsEnabled": true,
    "LoggingEnabled": true,
    "Otlp": {
      "Endpoint": "http://localhost:4318",
      "Protocol": "http/protobuf"
    },
    "Tracing": {
      "EnableConsoleExporter": true,
      "EnableOtlpExporter": true,
      "ExcludedPaths": ["^/health$", "^/metrics$", "^/live$", "^/ready$", "^/swagger/*"],
      "AdditionalSources": ["BBT.MyProjectName.*"],
      "Headers": ["sub", "act_sub", "jti", "role"]
    },
    "Metrics": {
      "EnableConsoleExporter": true,
      "EnableOtlpExporter": true,
      "AdditionalMeters": []
    },
    "Logging": {
      "EnableConsoleExporter": true,
      "EnableOtlpExporter": true,
      "IncludeFormattedMessage": true,
      "IncludeScopes": true,
      "ParseStateValues": true,
      "ExcludedPaths": ["^/health$", "^/metrics$", "^/live$", "^/ready$", "^/swagger/*"],
      "Enrichers": {
        "Headers": ["sub", "act_sub", "jti", "role"],
        "CustomAttributes": {

        }
      },
      "Body": {
        "EnableRequestBody": false,
        "EnableResponseBody": false,
        "MaxBodyLengthToCapture": 16384,
        "AdditionalSensitiveJsonFields": [],
        "AdditionalSensitiveHeaderNames": []
      }
    }
  }
}
